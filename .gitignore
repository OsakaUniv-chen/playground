__pycache__/
*.pyc
.DS_Store

# model checkpoints — never commit, regardless of path (see CLAUDE.md: no files >10MB)
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# videos — never commit, regardless of path
*.mp4

# PSSP: preprocessing-generated training data, never commit -- large,
# regeneratable from the raw rosbags (see train-pssp/CONTEXT.md).
*.npz
*.npy

# generated data tables — never commit, regenerable from raw data
*.parquet

# PSSP: training run outputs (checkpoints/logs/plots), regenerable by rerunning
train-pssp/*-run/train/runs/
